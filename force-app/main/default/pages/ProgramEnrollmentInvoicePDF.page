<apex:page controller="ProgramEnrollmentInvoiceController"
           renderAs="pdf" showHeader="false" applyBodyTag="false">
  <style>
    body, table { font-family: Helvetica, Arial, sans-serif; font-size:11px; line-height:1.4; }
    th { background:#f4f6f9; }
    h2 { margin:0 0 4px 0; }
  </style>

  <apex:variable var="pe" value="{!progEnroll}"/>

  <table width="100%">
    <tr>
      <td>
        <h2>Invoice - {!pe.Name}</h2>
        <div>Student: {!pe.hed__Contact__r.Name}</div>
        <div>Program: {!pe.hed__Account__r.Name}</div>
        <div>Enrollment Status: {!pe.hed__Enrollment_Status__c}</div>
        <div>
          Date:
          <apex:outputText value="{0,date,MMMM d, yyyy}">
            <apex:param value="{!NOW()}"/>
          </apex:outputText>
        </div>
      </td>
      <td align="right">
        <!-- Re-enabled logo; Static Resource must be named ImplemenationScienceLogo -->
        <img src="{!URLFOR($Resource.ImplemenationScienceLogo)}" width="180"/>
        <div style="font-size:10px; margin-top:4px; text-align:right;">
          Implementation Science Training Program<br/>
          University of California San Francisco
        </div>
      </td>
    </tr>
  </table>

  <h3 style="margin:14px 0 6px;">Course Connections</h3>
  <table width="100%" border="1" cellspacing="0" cellpadding="4">
    <tr>
      <th align="left">Course Connection ID</th>
      <th align="left">Course Name</th>
      <th align="left">Term</th>
      <th align="left">Course Start</th>
      <th align="left">Status</th>
      <th align="left">Role</th>
      <th align="right">Course Fee</th>
    </tr>
    <apex:repeat value="{!lines}" var="l">
      <tr>
        <td>{!l.Name}</td>
        <td>{!l.hed__Course_Offering__r.hed__Course__r.Name}</td>
        <td>{!l.Term_Name__c}</td>
        <td>
          <apex:outputText value="{0,date,MMM d, yyyy}">
            <apex:param value="{!l.hed__Course_Offering__r.hed__Start_Date__c}"/>
          </apex:outputText>
        </td>
        <td>{!l.hed__Status__c}</td>
        <td>{!l.Role__c}</td>
        <td align="right">
          <apex:outputText value="{0,number,$#,##0.00}">
            <apex:param value="{!l.Course_Fee__c}"/>
          </apex:outputText>
        </td>
      </tr>
    </apex:repeat>
    <tr>
      <td colspan="6" align="right"><b>Subtotal</b></td>
      <td align="right">
        <b>
          <apex:outputText value="{0,number,$#,##0.00}">
            <apex:param value="{!subtotal}"/>
          </apex:outputText>
        </b>
      </td>
    </tr>
    <apex:outputPanel rendered="{!taxAmount != null && taxAmount != 0}">
      <tr>
        <td colspan="6" align="right">Tax</td>
        <td align="right">
          <apex:outputText value="{0,number,$#,##0.00}">
            <apex:param value="{!taxAmount}"/>
          </apex:outputText>
        </td>
      </tr>
    </apex:outputPanel>
    <tr>
      <td colspan="6" align="right"><b>Total</b></td>
      <td align="right">
        <b>
          <apex:outputText value="{0,number,$#,##0.00}">
            <apex:param value="{!total}"/>
          </apex:outputText>
        </b>
      </td>
    </tr>
  </table>

  <div style="margin-top:16px; font-size:10px;">Thank you for your registration.</div>
</apex:page>